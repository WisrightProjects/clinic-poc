DATABASE_URL=postgresql://postgres:password@localhost:5432/doctor_attender

# Speech-to-text provider: 'whisper' (free, open-source, default) or 'sarvam' (paid).
# 'whisper' requires the stt-service/ sidecar to be running (see stt-service/README.md).
STT_PROVIDER=whisper
WHISPER_URL=http://localhost:8000
STT_LANGUAGE=auto

# Only used when STT_PROVIDER=sarvam:
SARVAM_API_KEY=

# AI summary provider: 'mock' (canned, default) or 'kimi' (paid, Moonshot AI — OpenAI-compatible API).
SUMMARY_PROVIDER=mock
SUMMARY_LANGUAGE=English
# Only used when SUMMARY_PROVIDER=kimi. Base URL must end in /v1.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=moonshot-v1-8k

AUDIO_DIR=./uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:8081
PORT=4000
